# === Firebase Client (NEXT_PUBLIC - seguro para o browser) ===
# Pegue em: Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=prosport-portfolio.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=prosport-portfolio
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=prosport-portfolio.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=785009102684
NEXT_PUBLIC_FIREBASE_APP_ID=1:785009102684:web:e3674ae9b10b1a2690bb99

# === Firebase Admin (SECRETO - apenas no servidor) ===
# Pegue em: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"prosport-portfolio",...}

# === Gemini AI ===
GEMINI_API_KEY=AIza...

# === App ===
# URL canônica do site — usada nos links de e-mail de verificação e nas URLs
# de retorno do Stripe. OBRIGATÓRIA em produção (Vercel): sem ela o app cai
# no header Host, que pode ser forjado (host header injection).
NEXT_PUBLIC_APP_URL=https://prosport.ia.br

# === Admin setup (opcional — deixe VAZIO/ausente em produção) ===
# Só defina temporariamente para promover uma conta a admin via
# /api/setup-admin?secret=..., e remova depois.
# ADMIN_SETUP_SECRET=
# ADMIN_SETUP_EMAIL=

# === Stripe Prices pré-criados (opcional, recomendado) ===
# Crie os Products/Prices no Stripe Dashboard e cole os IDs (price_...).
# Com eles, o Customer Portal consegue oferecer TROCA de plano; sem eles,
# o checkout usa price_data inline e o portal só cancela/atualiza cartão.
# STRIPE_PRICE_BASIC_MONTHLY=
# STRIPE_PRICE_BASIC_ANNUAL=
# STRIPE_PRICE_PLUS_MONTHLY=
# STRIPE_PRICE_PLUS_ANNUAL=
# STRIPE_PRICE_PREMIUM_MONTHLY=
# STRIPE_PRICE_PREMIUM_ANNUAL=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_ANNUAL=
